{
  "name": "pos-system",
  "version": "1.0.2",
  "description": "Professional POS System for Home Appliances Shop",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n API,WEB,ELECTRON \"npm run backend:dev\" \"npm run dev:renderer\" \"wait-on tcp:localhost:3000 http://localhost:5173 && npm run dev:electron\"",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev:renderer": "npm --prefix apps/renderer run dev",
    "backend:dev": "npm --prefix apps/backend run start:dev",
    "backend:build": "npm --prefix apps/backend run build",
    "build:backend": "npm --prefix apps/backend run build",
    "build:renderer": "npm --prefix apps/renderer run build:ci",
    "build:renderer:ci": "npm --prefix apps/renderer run build:ci",
    "prepare:backend-runtime": "node scripts/prepare-backend-runtime.mjs",
    "release:size-report": "node scripts/print-release-size-report.mjs",
    "build:electron:win": "electron-builder --win --publish never",
    "build:electron:mac": "electron-builder --mac --publish never",
    "backend:migrate": "npm --prefix apps/backend run prisma:migrate",
    "backend:seed": "npm --prefix apps/backend run prisma:seed",
    "build": "npm run build:backend && npm run build:renderer && npm run prepare:backend-runtime && electron-builder --publish never",
    "build:mac": "npm run build:backend && npm run build:renderer && npm run prepare:backend-runtime && npm run build:electron:mac",
    "build:win": "npm run build:backend && npm run build:renderer && npm run prepare:backend-runtime && npm run build:electron:win"
  },
  "author": "saad",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.pos.homeappliances",
    "productName": "POS System",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "compression": "store",
    "npmRebuild": false,
    "directories": {
      "output": "dist-electron"
    },
    "artifactName": "POS-System-${version}-${os}-${arch}.${ext}",
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "package.json",
      "!**/.git/**",
      "!**/.github/**",
      "!dist-electron/**",
      "!apps/renderer/node_modules/**",
      "!apps/backend/node_modules/**",
      "!node_modules/.cache/**",
      "!apps/renderer/src/**",
      "!apps/backend/src/**",
      "!apps/renderer/dist/**/*.map",
      "!apps/backend/**/*.map",
      "!apps/backend/tsconfig.tsbuildinfo",
      "!**/*.db",
      "!**/*.db-journal",
      "!**/*.sqlite",
      "!**/*.sqlite3",
      "!**/*.log",
      "!screenshots/**",
      "!**/*.bak",
      "!**/*.backup"
    ],
    "extraResources": [
      {
        "from": "apps/renderer/dist",
        "to": "renderer/dist",
        "filter": [
          "**/*",
          "!**/*.map"
        ]
      },
      {
        "from": "release/backend-runtime",
        "to": "backend",
        "filter": [
          "**/*",
          "!dist/**/*.map",
          "!node_modules/**/*.map",
          "!node_modules/**/*.md",
          "!node_modules/**/CHANGELOG*",
          "!node_modules/**/LICENSE*",
          "!node_modules/**/README*",
          "!node_modules/**/docs/**",
          "!node_modules/**/doc/**",
          "!node_modules/**/test/**",
          "!node_modules/**/tests/**",
          "!node_modules/**/__tests__/**",
          "!node_modules/**/coverage/**",
          "!**/*.tsbuildinfo",
          "!**/.cache/**",
          "!**/*.db",
          "!**/*.db-journal",
          "!**/*.sqlite",
          "!**/*.sqlite3",
          "!**/*.log"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        "zip"
      ],
      "artifactName": "POS-System-${version}-win-x64.${ext}"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
